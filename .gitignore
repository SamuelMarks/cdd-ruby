dist/
/docs/
/build/
/custom_bin/
/*.wasm
/coverage/
/doc/
/.yardoc/
/*.gem

# We want to track bin/cdd-ruby, so ignore other contents but not bin itself
/bin/*
!/bin/cdd-ruby

# Generated output directories
/out_*/
/out_cli/
/out_sdk/
/out_server/

# Test / Scratch files
/massive*.json
/massive*.txt
/test_*.json
/test_*.rb
/patch*.rb

# Temporary generated test output directories
test_*/
*test_dir/
scaffold_test_dir/

# Temporary files created by scripts
/fix_*.rb
/update_*.rb
/replace_*.rb
/print_*.rb
/temp_*.rb

# Common dummy files used in specs
dummy.json
dummy_*.json
dummy*.rb

# Output artifacts
/sdk.rb
/sdk_cli.rb
/server.rb
/docs.json

# Test / Temporary files
/rubies/
Dockerfile.test*
test_out.txt
.bundle/
ruby-*-wasm32-*/
vendor/
# Gemfile.lock

node_modules/
__pycache__/
*.o
*.so
target/
.idea/
spec.json
# Dummy directories for tests
/dummy_cli/
/dummy_sdk/
/dummy_server/
/dummy_*/

# Ignore tmp or custom dev directories
/tmp/
/temp/

# Ignore compiled/generated artifacts more broadly
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
env.bak/
venv.bak/
.DS_Store
*.log
*.sqlite3
*.db
coverage/
.coverage
*.bak

# Generated client SDK directories
/cdd-ruby-client-*/

# ----------------------------------------------------------------------
# Aggressive Catch-all Wildcards (for carefree git add .)
# ----------------------------------------------------------------------

# Coverage & Tests
coverage/
.coverage
coverage.json
.resultset.json
.resultset.json.lock
.last_run.json

# C/C++ compiled objects
*.o
*.so
*.a
*.lib
*.dll
*.exe
*.out
*.app
*.class
*.jar
*.war

# Temporary, dummy and scratch files
dummy*
temp*
tmp*
patch*.rb
test_*.rb
fix_*.rb
update_*.rb
replace_*.rb
print_*.rb
massive*.json
massive*.txt
err*.txt
out*.txt
prompt*.md
*.log
*.bak
*.swp
*.swo
*~
.DS_Store

# Virtual environments & Dependencies
node_modules/
vendor/
.bundle/
__pycache__/
env/
venv/
.venv/

# Build and IDE
[bB]uild/
[dD]ist/
[oO]ut*/
.idea/
.vscode/
*.wasm
*.wat
*.gem

# Ensure we keep what we need
!/bin/cdd-ruby
!.github/
