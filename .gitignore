dist/
/docs/
/build/
/custom_bin/
/*.wasm
/coverage/
/doc/
/.yardoc/
/*.gem

# We want to track bin/cdd-ruby, so ignore other contents but not bin itself
/bin/*
!/bin/cdd-ruby

# Generated output directories
/out_*/
/out_cli/
/out_sdk/
/out_server/

# Test / Scratch files
/massive*.json
/massive*.txt
/test_*.json
/test_*.rb
/patch_*.rb

# Temporary generated test output directories
test_*/
*test_dir/
scaffold_test_dir/

# Temporary files created by scripts
fix_*.rb
update_*.rb
replace_*.rb
print_*.rb
temp_*.rb

# Common dummy files used in specs
dummy.json
dummy_*.json
dummy.rb

# Output artifacts
sdk.rb
sdk_cli.rb
server.rb
docs.json

# Test / Temporary files
/rubies/
Dockerfile.test*
test_out.txt
.bundle/
ruby-*-wasm32-*/
vendor/
Gemfile.lock

node_modules/
__pycache__/
*.o
*.so
target/
.idea/
spec.json
# Dummy directories for tests
/dummy_cli/
/dummy_sdk/
/dummy_server/
/dummy_*/

# Ignore tmp or custom dev directories
/tmp/
/temp/

# Ignore compiled/generated artifacts more broadly
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
env.bak/
venv.bak/
.DS_Store
*.log
*.sqlite3
*.db
coverage/
.coverage
